# ── Call Fi — Frontend Environment Variables ─────────────────────────────────
# Copy this to .env.local for local dev.
# Add both to Vercel dashboard → Settings → Environment Variables.
RELAYER_PRIVATE_KEY=0x353fa2b4ff133910fc2b202928528751fae16b4db56991818f940b561935b041

# Deployed CallFi.sol address on Somnia Testnet
# Get this after running: npm run deploy:somnia (in the root somnia-call/ dir)
NEXT_PUBLIC_CALLFI_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect / Web3Modal Project ID
# Create one free at https://cloud.walletconnect.com → New Project → App
# Unlocks MetaMask, Coinbase, Rainbow, WalletConnect + 200 more wallets
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id_here
