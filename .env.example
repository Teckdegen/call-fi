# Run "npm run wallet" to generate a fresh wallet, then paste the private key here.
# Fund the address at https://testnet.somnia.network/faucet before deploying.
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# Server-side relayer key — pays gas for ALL users (zero wallet popups).
# Can be the same key as DEPLOYER_PRIVATE_KEY for simplicity.
# Keep this SECRET — never commit it, never expose it client-side.
# Fund this address with STT so it can pay gas: https://testnet.somnia.network/faucet
RELAYER_PRIVATE_KEY=your_relayer_private_key_here